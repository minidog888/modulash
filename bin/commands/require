#!/usr/bin/env bash
# ============================================
# Command: require — Add a dependency to modulash.json and install it
# ============================================

import "@/lib/module.sh" 2>/dev/null || true

cmd_require_description() {
    echo "Add a dependency to modulash.json and install it"
}

cmd_require_options() {
    clish_console_core_options_option "dev" "Add to devDependencies instead of dependencies"
    clish_console_core_options_option "dry-run" "Preview changes without modifying files"
    clish_console_core_options_option "force" "Force install even if already installed"
    clish_console_core_options_argument "package" "Package name (vendor/name)"
    clish_console_core_options_argument "version" "Version constraint (default: *)" --optional
}

cmd_require_handle() {
    local dev="${opt_dev:-false}"
    local dry_run="${opt_dry_run:-false}"
    local force="${opt_force:-false}"

    local package="${arg_package:-}"
    local version="${arg_version:-*}"
    if [[ -z "$package" ]]; then
        clish_console_core_log_error "Package name is required."
        clish_console_core_log_info "Usage: require <package> [version]"
        return 1
    fi

    if [[ ! "$package" =~ ^[a-z0-9_-]+/[a-z0-9_-]+$ ]]; then
        clish_console_core_log_error "Invalid package name format. Use vendor/name."
        return 1
    fi

    clish_console_core_log_info "Requiring $package ($version)"

    local registry_url
    registry_url="$(module_get_registry_url)"
    if [[ -z "$registry_url" ]]; then
        clish_console_core_log_error "No registry URL configured."
        return 1
    fi

    local api_url="$registry_url/$package"
    local package_info
    if ! package_info=$(curl -s "$api_url"); then
        clish_console_core_log_error "Failed to fetch package info from $api_url"
        return 1
    fi
    if ! echo "$package_info" | jq -e . >/dev/null 2>&1; then
        clish_console_core_log_error "Invalid response from registry"
        return 1
    fi

    local versions
    versions=($(echo "$package_info" | jq -r '.versions[].version' | sort -V))
    if [[ ${#versions[@]} -eq 0 ]]; then
        clish_console_core_log_error "No versions available for $package"
        return 1
    fi

    local matched_version
    matched_version="$(module_match_version "$version" "${versions[@]}")"
    if [[ -z "$matched_version" ]]; then
        clish_console_core_log_error "No version matches constraint '$version'"
        return 1
    fi

    clish_console_core_log_info "Selected version: $matched_version"

    if [[ -d "$PWD/vendor/$package" ]] && [[ "$force" != "true" ]]; then
        clish_console_core_log_warning "Package $package already installed. Use --force to reinstall."
    fi

    if [[ "$dry_run" == "true" ]]; then
        clish_console_core_log_info "Dry-run: would add $package $matched_version to $([[ "$dev" == "true" ]] && echo "devDependencies" || echo "dependencies") and install it"
        return 0
    fi

    local config_file="$PWD/modulash.json"
    if [[ ! -f "$config_file" ]]; then
        clish_console_core_log_error "modulash.json not found. Run 'modulash init' first."
        return 1
    fi

    local tmp_json="${config_file}.tmp"
    local dep_key
    if [[ "$dev" == "true" ]]; then
        dep_key="devDependencies"
    else
        dep_key="dependencies"
    fi

    if ! jq --arg key "$dep_key" --arg pkg "$package" --arg ver "$matched_version" \
        '.[$key][$pkg] = $ver' "$config_file" > "$tmp_json"; then
        clish_console_core_log_error "Failed to update modulash.json"
        return 1
    fi
    mv "$tmp_json" "$config_file"
    clish_console_core_log_success "Added $package to $dep_key"

    clish_console_core_log_info "Installing $package ..."
    if ! module_install_dependency "$package" "$matched_version"; then
        clish_console_core_log_error "Installation failed, rolling back modulash.json..."
        jq --arg key "$dep_key" --arg pkg "$package" '.[$key] |= del(.[$pkg])' "$config_file" > "$tmp_json"
        mv "$tmp_json" "$config_file"
        return 1
    fi

    clish_console_core_log_success "Package $package installed successfully."
    return 0
}